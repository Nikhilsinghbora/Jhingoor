# Copy to .env — Expo inlines EXPO_PUBLIC_* at build time.

# FastAPI base URL (must include /api/v1)
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Google Sign-In (optional — native client IDs from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
