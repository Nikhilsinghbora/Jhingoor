# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
ENVIRONMENT=development
DEBUG=True

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
TELEGRAM_BOT_TOKEN=
WEBHOOK_URL=
WEBHOOK_PATH=/webhook

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/jhingoor_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jhingoor_db
DB_USER=
DB_PASSWORD=
DB_SSL_MODE=disable

# =============================================================================
# GOOGLE AI / GEMINI CONFIGURATION
# =============================================================================
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
# Use a v1beta-supported id (unversioned gemini-1.5-flash is rejected). See src/bot/brain.py.
# When USE_VERTEX_AI=true, use a Vertex model id (often with -001 suffix). See src/bot/brain.py.
GOOGLE_AI_MODEL=gemini-2.0-flash-001
GOOGLE_AI_TEMPERATURE=0.7
GOOGLE_AI_MAX_TOKENS=1024

# =============================================================================
# FASTAPI / UVICORN CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=True
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECRET_KEY=

# =============================================================================
# RATE LIMITING & PERFORMANCE
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
MAX_CONCURRENT_REQUESTS=10
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
MAX_FILE_SIZE_MB=50
UPLOAD_DIRECTORY=./uploads
TEMP_DIRECTORY=./temp

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_TTL=3600

# =============================================================================
# MOBILE API (FastAPI) — see src/api/config.py
# =============================================================================
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=
CORS_ORIGINS=*

# Alembic migrations (sync driver; optional if DB_* are set — see alembic/env.py)
ALEMBIC_SYNC_DATABASE_URL=

# Telegram bot token (src/main.py)
TELEGRAM_TOKEN=

# Gemini / chat (src/bot/brain.py) — default to Vertex AI; use gcloud auth application-default login
AI_MODEL=gemini-2.0-flash-001
USE_VERTEX_AI=true
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1